// ============================================================================
// PULSE Fintech — Prisma Schema
// ============================================================================
//
// PostgreSQL Migration Plan:
// When migrating to PostgreSQL:
//   1. Change provider from "sqlite" to "postgresql"
//   2. Update DATABASE_URL to a PostgreSQL connection string
//   3. Change all Float fields back to Decimal @db.Decimal(18, 2):
//      - Account.balance
//      - Transaction.amount
//      - Invoice.amount
//      - Invoice.taxAmount
//      - Project.budget
//   4. Run prisma migrate dev to generate the migration
//
// Current: SQLite for development — Float used instead of Decimal
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// === AUTH ===

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          UserRole  @default(VIEWER)
  passwordHash  String?           // For credentials provider
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      OAuthAccount[]
  memberships   OrganizationMember[]
  approvals     ApprovalStep[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  inn         String?
  kpp         String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts      Account[]
  memberships   OrganizationMember[]
  categories    Category[]
  counterparties Counterparty[]
  projects      Project[]
  rules         Rule[]
  auditLogs     AuditLog[]
  budgetItems   BudgetItem[]
  notifications Notification[]

  @@map("organizations")
}

// NextAuth OAuth Account (separate from financial Account model)
model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String   // oauth, oidc, etc.
  provider          String   // google, github, etc.
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole @default(VIEWER)
  joinedAt       DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// === FINANCIAL CORE ===

model Account {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  type           AccountType
  currency       String      @default("RUB")
  balance        Float       @default(0)
  bankName       String?
  bankBik        String?
  accountNumber  String?
  isDefault      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@map("accounts")
}

enum AccountType {
  CHECKING
  SAVINGS
  CASH
  CREDIT
  DEPOSIT
}

model Transaction {
  id              String            @id @default(cuid())
  organizationId  String
  accountId       String
  counterpartyId  String?
  categoryId      String?
  projectId       String?
  type            TransactionType
  amount          Float
  description     String?
  reference       String?
  status          TransactionStatus @default(PENDING)
  transactionDate DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  account         Account           @relation(fields: [accountId], references: [id])
  counterparty    Counterparty?     @relation(fields: [counterpartyId], references: [id])
  category        Category?         @relation(fields: [categoryId], references: [id])
  project         Project?          @relation(fields: [projectId], references: [id])
  invoice         Invoice?          @relation(fields: [invoiceId], references: [id])
  invoiceId       String?
  auditLogs       AuditLog[]

  @@index([organizationId, transactionDate])
  @@index([organizationId, status])
  @@index([accountId])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Counterparty {
  id              String            @id @default(cuid())
  organizationId  String
  name            String
  inn             String?
  type            CounterpartyType  @default(COMPANY)
  email           String?
  phone           String?
  address         String?
  contactPerson   String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  invoices        Invoice[]
  documents       Document[]

  @@index([organizationId, name])
  @@map("counterparties")
}

enum CounterpartyType {
  COMPANY
  INDIVIDUAL
  PERSON
}

model Category {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  type            CategoryType
  icon            String?
  color           String?
  parentId        String?
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent          Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        Category[]   @relation("CategoryHierarchy")
  transactions    Transaction[]
  budgetItems     BudgetItem[]

  @@unique([organizationId, name, type])
  @@map("categories")
}

enum CategoryType {
  INCOME
  EXPENSE
}

// === INVOICES & DOCUMENTS ===

model Invoice {
  id              String        @id @default(cuid())
  organizationId  String
  counterpartyId  String
  number          String
  status          InvoiceStatus @default(DRAFT)
  type            InvoiceType   @default(SALES)
  amount          Float
  taxAmount       Float?
  dueDate         DateTime?
  issuedDate      DateTime?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  counterparty    Counterparty  @relation(fields: [counterpartyId], references: [id])
  transactions    Transaction[]
  documents       Document[]

  @@index([organizationId, status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum InvoiceType {
  SALES
  PURCHASE
}

model Document {
  id              String         @id @default(cuid())
  organizationId  String
  counterpartyId  String?
  invoiceId       String?
  type            DocumentType
  title           String
  fileUrl         String?
  fileName        String?
  status          DocumentStatus @default(DRAFT)
  signedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  counterparty    Counterparty?  @relation(fields: [counterpartyId], references: [id])
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])

  @@map("documents")
}

enum DocumentType {
  CONTRACT
  INVOICE
  ACT
  INVOICE_ESF
  WAYBILL
  OTHER
}

enum DocumentStatus {
  DRAFT
  SENT
  SIGNED
  REJECTED
  ARCHIVED
}

// === PROJECTS ===

model Project {
  id              String        @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  status          ProjectStatus @default(ACTIVE)
  budget          Float?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// === RULES & APPROVALS ===

model Rule {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  condition       String       // JSON string in SQLite
  action          String       // JSON string in SQLite
  isActive        Boolean      @default(true)
  priority        Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("rules")
}

model Approval {
  id              String         @id @default(cuid())
  organizationId  String
  type            ApprovalType
  entityType      String
  entityId        String
  status          ApprovalStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  steps           ApprovalStep[]

  @@map("approvals")
}

enum ApprovalType {
  INVOICE
  EXPENSE
  TRANSFER
  BUDGET
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalStep {
  id          String         @id @default(cuid())
  approvalId  String
  approverId  String
  status      ApprovalStatus @default(PENDING)
  comment     String?
  actedAt     DateTime?

  approval    Approval       @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  approver    User           @relation(fields: [approverId], references: [id])

  @@map("approval_steps")
}

// === NOTIFICATIONS ===

model Notification {
  id              String   @id @default(cuid())
  userId          String
  type            String   // invoice_overdue, approval_needed, etc.
  channel         String   @default("in_app") // in_app, email, push
  title           String
  message         String
  entityType      String?  // Invoice, Transaction, etc.
  entityId        String?
  payload         String?  // JSON string in SQLite
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String?

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// === BUDGET ===

model BudgetItem {
  id              String   @id @default(cuid())
  organizationId  String
  categoryId      String
  year            Int
  month           Int?     // null = annual, 1-12 = monthly
  amount          Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category        Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([organizationId, categoryId, year, month])
  @@map("budget_items")
}

// === AUDIT ===

model AuditLog {
  id              String       @id @default(cuid())
  organizationId  String?
  userId          String?
  action          String
  entityType      String
  entityId        String?
  oldValue        String?
  newValue        String?
  createdAt       DateTime     @default(now())

  organization    Organization? @relation(fields: [organizationId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])
  transaction     Transaction?  @relation(fields: [transactionId], references: [id])
  transactionId   String?

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}
